--- !u!114 &1675911677
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1675911674}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9117653835b354259a0c03ce702840f6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueBalloonAction
  textToDisplay: Hopefully, some of the spirits who live there can help me out.
  backgroundColor: {r: 0, g: 0, b: 0, a: 1}
  textColor: {r: 1, g: 1, b: 1, a: 1}
  audioSrc: {fileID: 0}
  targetObject: {fileID: 247053829}
  disappearMode: 1
  timeToDisappear: 2
  keyToPress: 13
  followingText: {fileID: 1675911676}
  playerScript: {fileID: 0}
--- !u!114 &1675911678
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1675911674}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9117653835b354259a0c03ce702840f6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueBalloonAction
  textToDisplay: "And, in its state, my boat can\u2019t travel all of the rivers."
  backgroundColor: {r: 0, g: 0, b: 0, a: 1}
  textColor: {r: 1, g: 1, b: 1, a: 1}
  audioSrc: {fileID: 0}
  targetObject: {fileID: 247053829}
  disappearMode: 1
  timeToDisappear: 2
  keyToPress: 13
  followingText: {fileID: 1675911677}
  playerScript: {fileID: 0}
--- !u!114 &1675911679
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1675911674}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9117653835b354259a0c03ce702840f6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueBalloonAction
  textToDisplay: Rumors are that shadow creatures have been disturbing the rivers.
  backgroundColor: {r: 0, g: 0, b: 0, a: 1}
  textColor: {r: 1, g: 1, b: 1, a: 1}
  audioSrc: {fileID: 0}
  targetObject: {fileID: 247053829}
  disappearMode: 1
  timeToDisappear: 2
  keyToPress: 13
  followingText: {fileID: 1675911678}
  playerScript: {fileID: 0}
